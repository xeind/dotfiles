{
  "sticky_scroll": {
    "enabled": true
  },
  "which_key": {
    "enabled": true
  },
  "agent_buffer_font_size": 14.0,
  "selection_highlight": false,
  "session": {
    "restore_unsaved_buffers": false
  },
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "always",
    "use_smartcase_find": true
  },
  "show_edit_predictions": false,
  "disable_ai": false,
  "unnecessary_code_fade": 0.3,
  "rounded_selection": false,
  "buffer_font_weight": 400.0,
  "colorize_brackets": true,
  "gutter": {
    "runnables": true,
    "breakpoints": false,
    "folds": true
  },
  "git_panel": {
    "scrollbar": {
      "show": "auto"
    }
  },
  "ui_font_weight": 450.0,
  "preview_tabs": {
    "enable_preview_from_file_finder": false
  "git": {
    "blame": {
      "show_avatar": false
    },
    "branch_picker": {
      "show_author_name": true
    },
    "inline_blame": {
      "delay_ms": 600,
      "enabled": true,
      "padding": 4
    }
  },
  "project_panel": {
    "hide_root": false,
    "auto_fold_dirs": false,
    "auto_reveal_entries": true,
    "indent_size": 14.0,
    "folder_icons": false,
    "file_icons": true,
    "hide_gitignore": false
  },
  "file_finder": {
    "file_icons": true
  },
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "restore_on_startup": "last_workspace",
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  "title_bar": {
    "show_menus": true,
    "show_sign_in": false,
    "show_user_picture": true,
    "show_branch_icon": false
  },
  "relative_line_numbers": "enabled",
  "active_pane_modifiers": {
    "border_size": 2.0
  },
  "ui_font_features": {
    "calt": 0
  },
  "ui_font_family": "Inter",
  "icon_theme": {
    "mode": "system",
    "light": "Colored Zed Icons Theme Dark",
    "dark": "Colored Zed Icons Theme Dark"
  },
  "terminal": {
    "cursor_shape": "block",
    "option_as_meta": true,
    "dock": "bottom",
    "font_family": "TX-02 Condensed",
    "font_features": {
      "calt": 0,
      "ss03": 1,
      "ss05": 1
    }
  },
  "edit_predictions": {
    "mode": "eager",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null
    },
    "enabled_in_text_threads": false
  },
  "cursor_blink": false,
  "cursor_shape": "bar",
  "buffer_font_size": 18.0,
  "buffer_font_family": "TX-02 Condensed",
  "buffer_font_features": { "ss01": true },
  //"base_keymap": "VSCode",
  "vim_mode": true,
  "command_aliases": {
    "W": "w",
    "Wq": "wq",
    "Q": "q"
  },
  "ui_font_size": 14,
  "theme": "Nightingale",
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5"
    }
  }
}
